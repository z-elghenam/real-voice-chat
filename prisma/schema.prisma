generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Room {
  id                String   @id @default(cuid())
  name              String
  description       String
  maxParticipants   Int      @default(25)
  createdBy         String
  participantsCount Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
